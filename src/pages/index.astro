---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.hero {
				padding: 4rem 2rem;
				text-align: center;
				background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
				color: white;
				border-radius: 12px;
				margin-bottom: 2rem;
			}
			.hero h1 {
				margin: 0;
				font-size: 3rem;
				color: white;
			}
			.hero p {
				font-size: 1.25rem;
				opacity: 0.9;
			}
			.featured-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 1.5rem;
			}
			.posts {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 2rem;
				list-style-type: none;
				padding: 0;
			}
			.post-card {
				text-decoration: none;
				transition: transform 0.2s ease;
			}
			.post-card:hover {
				transform: translateY(-4px);
			}
			.post-card img {
				width: 100%;
				border-radius: 8px;
				margin-bottom: 0.5rem;
			}
			.post-card h3 {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.5rem;
			}
			.post-card .date {
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			.industries {
				margin-top: 4rem;
				padding: 2rem;
				background-color: #f8f9fa;
				border-radius: 12px;
			}
			.industries h2 {
				text-align: center;
				margin-bottom: 2rem;
			}
			.industry-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
				gap: 1rem;
				text-align: center;
			}
			.industry-tag {
				padding: 0.5rem;
				background: white;
				border: 1px solid #ddd;
				border-radius: 20px;
				font-size: 0.9rem;
				font-weight: 500;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
			</section>

			<section>
				<div class="featured-header">
					<h2>Latest Insights</h2>
					<a href="/blog">View all posts &rarr;</a>
				</div>
				<div class="posts">
					{
						posts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								{post.data.heroImage && (
									<img width={720} height={360} src={post.data.heroImage} alt="" />
								)}
								<h3>{post.data.title.replace(/\[(.*?)\]\(.*?\)/g, '$1')}</h3>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						))
					}
				</div>
			</section>

			<section class="industries">
				<h2>Industries We Cover</h2>
				<div class="industry-grid">
					<div class="industry-tag">Biotech</div>
					<div class="industry-tag">Fintech</div>
					<div class="industry-tag">Edtech</div>
					<div class="industry-tag">Manufacturing</div>
					<div class="industry-tag">Healthcare</div>
					<div class="industry-tag">Logistics</div>
					<div class="industry-tag">Real Estate</div>
					<div class="industry-tag">E-commerce</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
